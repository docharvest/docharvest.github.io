---
import TechDocsLayout from '../../../layouts/TechDocsLayout.astro';
import { getAllPages, getPack, getPacks, getPage, getPagesForTech } from '../../../lib/docs';

export function getStaticPaths() {
  const techs = new Set(getPacks().map((p) => p.id));
  for (const page of getAllPages()) techs.add(page.tech);
  return [...techs].map((tech) => ({ params: { tech } }));
}

const { tech } = Astro.params;
if (!tech) throw new Error('missing tech');

const pack = getPack(tech);
const indexPage = getPage(tech, '');
const pages = getPagesForTech(tech);
const Content = indexPage?.Content;
const title = indexPage?.title ?? pack?.title ?? tech;
const description = indexPage?.description || pack?.description || '';
const base = import.meta.env.BASE_URL;
---

<TechDocsLayout tech={tech} title={title} description={description} slugPath="">
  {
    Content ? (
      // @ts-expect-error MD/MDX component
      <Content />
    ) : (
      <div class="not-prose">
        {pack?.description && <p class="text-base-content/80 text-pretty">{pack.description}</p>}
        {pages.length === 0 ? (
          <p class="mt-4 text-sm text-warning">
            No content placed yet. Run <code class="rounded bg-base-200 px-1">workspaced codebase apply</code> after declaring the pack in <code class="rounded bg-base-200 px-1">workspaced.cue</code>.
          </p>
        ) : (
          <ul class="mt-6 divide-y divide-base-300 rounded-box border border-base-300">
            {pages
              .filter((p) => p.slugPath)
              .map((p) => (
                <li>
                  <a
                    href={`${base}docs/${tech}/${p.slugPath}/`}
                    class="flex flex-col gap-0.5 px-4 py-3 hover:bg-base-200/50 sm:flex-row sm:justify-between"
                  >
                    <span class="font-medium">{p.title}</span>
                    <span class="text-sm text-base-content/60">{p.slugPath}</span>
                  </a>
                </li>
              ))}
          </ul>
        )}
        <p class="mt-6 text-sm">
          Agent index:{' '}
          <a class="link link-primary" href={`${base}docs/${tech}/llms.txt`}>llms.txt</a>
        </p>
      </div>
    )
  }
</TechDocsLayout>
