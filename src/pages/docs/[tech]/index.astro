---
import DocContent from '../../../components/DocContent.astro';
import TechDocsLayout from '../../../layouts/TechDocsLayout.astro';
import { getAllPages, getPack, getPacks, getPage, getPagesForTech } from '../../../lib/docs';

export function getStaticPaths() {
  const techs = new Set(getPacks().map((p) => p.id));
  for (const page of getAllPages()) techs.add(page.tech);
  return [...techs].map((tech) => ({ params: { tech } }));
}

const { tech } = Astro.params;
if (!tech) throw new Error('missing tech');

const pack = getPack(tech);
const indexPage = getPage(tech, '');
const pages = getPagesForTech(tech);
const hasBody = Boolean(indexPage?.Content || indexPage?.html);
const title = indexPage?.title ?? pack?.title ?? tech;
const description = indexPage?.description || pack?.description || '';
const base = import.meta.env.BASE_URL;
const hasContentTitle = Boolean(
  indexPage?.html?.includes('<h1') ||
    indexPage?.headings?.some((h) => h.depth === 1),
);
---

<TechDocsLayout tech={tech} title={title} description={description} slugPath="" hasContentTitle={hasBody && hasContentTitle}>
  {
    hasBody ? (
      <DocContent Content={indexPage?.Content} html={indexPage?.html} />
    ) : (
      <div class="not-prose">
        {pack?.description && <p class="text-base-content/70 leading-relaxed text-pretty">{pack.description}</p>}
        <ul class="mt-8 divide-y divide-base-300 border-y border-base-300">
          {pages
            .filter((p) => p.slugPath)
            .slice(0, 40)
            .map((p) => (
              <li>
                <a
                  href={`${base}docs/${tech}/${p.slugPath}/`}
                  class="flex flex-col gap-0.5 py-3 hover:bg-base-200/40 sm:flex-row sm:justify-between sm:gap-6"
                >
                  <span class="font-medium">{p.title}</span>
                  <span class="font-mono text-xs text-base-content/45">{p.slugPath}</span>
                </a>
              </li>
            ))}
        </ul>
        {pages.length > 40 && (
          <p class="mt-3 text-sm text-base-content/50">…and {pages.length - 40} more in the sidebar.</p>
        )}
        <p class="mt-6 text-sm text-base-content/60">
          <a class="link link-primary" href={`${base}docs/${tech}/llms.txt`}>llms.txt</a> for agents
        </p>
      </div>
    )
  }
</TechDocsLayout>
