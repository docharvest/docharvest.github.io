---
import DocContent from '../../../components/DocContent.astro';
import TechDocsLayout from '../../../layouts/TechDocsLayout.astro';
import { getAllPagesAsync } from '../../../lib/docs';

export async function getStaticPaths() {
  const all = await getAllPagesAsync();
  return all
    .filter((p) => p.slugPath)
    .map((page) => ({
      params: { tech: page.tech, slug: page.slugPath },
      props: { page },
    }));
}

const { page } = Astro.props;
const hasContentTitle = Boolean(
  page.html?.includes('<h1') || page.headings?.some((h) => h.depth === 1),
);
---

<TechDocsLayout
  tech={page.tech}
  title={page.title}
  description={page.description}
  slugPath={page.slugPath}
  hasContentTitle={hasContentTitle}
>
  <DocContent Content={page.Content} html={page.html} />
</TechDocsLayout>
