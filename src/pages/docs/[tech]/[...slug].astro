---
import DocContent from '../../../components/DocContent.astro';
import TechDocsLayout from '../../../layouts/TechDocsLayout.astro';
import { getAllPages } from '../../../lib/docs';

export function getStaticPaths() {
  return getAllPages()
    .filter((p) => p.slugPath)
    .map((page) => ({
      params: { tech: page.tech, slug: page.slugPath },
      props: { page },
    }));
}

const { page } = Astro.props;
---

<TechDocsLayout
  tech={page.tech}
  title={page.title}
  description={page.description}
  slugPath={page.slugPath}
>
  <DocContent Content={page.Content} html={page.html} />
</TechDocsLayout>
