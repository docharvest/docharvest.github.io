---
import DocContent from '../../../components/DocContent.astro';
import TechDocsLayout from '../../../layouts/TechDocsLayout.astro';
import { getAllPages } from '../../../lib/docs';

export function getStaticPaths() {
  return getAllPages()
    .filter((p) => p.slugPath)
    .map((page) => ({
      params: { tech: page.tech, slug: page.slugPath },
      props: { page },
    }));
}

const { page } = Astro.props;
// Astro MD often starts with # Title matching frontmatter; OpenCV html has <h1>
const hasContentTitle = Boolean(
  page.html?.includes('<h1') ||
    (page.headings?.some((h) => h.depth === 1)),
);
---

<TechDocsLayout
  tech={page.tech}
  title={page.title}
  description={page.description}
  slugPath={page.slugPath}
  hasContentTitle={hasContentTitle}
>
  <DocContent Content={page.Content} html={page.html} />
</TechDocsLayout>
