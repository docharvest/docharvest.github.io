---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPagesAsync, getPacks, getPagesForTech } from '../../lib/docs';

await getAllPagesAsync();

const base = import.meta.env.BASE_URL;
const packs = getPacks().map((p) => ({
  ...p,
  pageCount: getPagesForTech(p.id).length,
}));
---

<BaseLayout title="Documentation" description="Documentation packs harvested into docharvest.">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-10 max-w-2xl">
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Documentation packs</h1>
      <p class="mt-3 text-base-content/80 text-pretty">
        Each pack is a tech id under <code class="rounded-field bg-base-200 px-1.5 py-0.5 text-sm">/docs/:tech</code>.
        Agent-oriented indexes are <strong>tech-specific only</strong> — open
        <code class="rounded-field bg-base-200 px-1.5 py-0.5 text-sm">/docs/:tech/llms.txt</code>.
      </p>
    </header>
    <ul class="divide-y divide-base-300 rounded-box border border-base-300 bg-base-100">
      {
        packs.map((p) => (
          <li>
            <a
              href={`${base}docs/${p.id}/`}
              class="flex flex-col gap-1 px-5 py-4 transition-colors hover:bg-base-200/50 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6"
            >
              <span class="font-medium">{p.title}</span>
              <span class="text-sm text-base-content/70 sm:text-right">
                {p.description}
                {p.pageCount > 0 ? ` · ${p.pageCount} pages` : ''}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
