---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PackLogo from '../../components/PackLogo.astro';
import { getPackSummaries } from '../../lib/docs';

const base = import.meta.env.BASE_URL;
const packs = await getPackSummaries();
---

<BaseLayout title="Documentation" description="Vendored documentation packs on docharvest.">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-10 max-w-2xl">
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Documentation packs</h1>
      <p class="mt-3 text-base-content/80 text-pretty">
        Each pack is a tech id under <code class="rounded-field bg-base-200 px-1.5 py-0.5 text-sm">/docs/:tech</code>.
        Logos use the GitHub owner avatar for the upstream repo.
      </p>
    </header>
    <ul class="divide-y divide-base-300 rounded-box border border-base-300 bg-base-100">
      {
        packs.map((p) => (
          <li>
            <a
              href={`${base}docs/${p.id}/`}
              class="flex flex-col gap-3 px-5 py-4 transition-colors hover:bg-base-200/50 sm:flex-row sm:items-center sm:gap-4"
            >
              <PackLogo logo={p.logo} title={p.title} size={36} />
              <span class="min-w-0 flex-1">
                <span class="font-medium">{p.title}</span>
                <span class="mt-1 block text-sm text-base-content/70 text-pretty">
                  {p.description}
                  {p.pageCount > 0 ? ` · ${p.pageCount} pages` : ''}
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
