---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPacks, getPagesForTech } from '../lib/docs';

const base = import.meta.env.BASE_URL;
const packs = getPacks().map((p) => ({
  ...p,
  pageCount: getPagesForTech(p.id).length,
}));
---

<BaseLayout
  title="docharvest"
  description="Harvested documentation packs for tools and ecosystems. Each pack is vendored with workspaced and exposes a tech-specific llms.txt for agents."
>
  <section class="border-b border-base-300 bg-base-100">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
      <p class="mb-3 text-sm font-medium text-primary">documentation harvest</p>
      <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl">
        Docs packs for humans and agents
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/80 text-pretty">
        docharvest vendors upstream documentation into versioned packs managed by
        <a class="link link-primary" href="https://github.com/lucasew/workspaced" target="_blank" rel="noopener noreferrer">workspaced</a>.
        Browse at <code class="rounded-field bg-base-200 px-1.5 py-0.5 text-sm">/docs/:tech</code>.
        Agents get <strong class="font-semibold text-base-content">per-tech</strong>
        <code class="rounded-field bg-base-200 px-1.5 py-0.5 text-sm">llms.txt</code> — never a site-wide index.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary rounded-field shadow-none" href={`${base}docs/`}>Browse packs</a>
        <a
          class="btn btn-outline border-base-300 rounded-field shadow-none"
          href="https://github.com/docharvest/docharvest.github.io"
          target="_blank"
          rel="noopener noreferrer"
        >
          Site source
        </a>
      </div>
    </div>
  </section>

  <section class="border-b border-base-300 bg-base-200/50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold tracking-tight">How packs work</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <div class="rounded-box border border-base-300 bg-base-100 p-5">
          <h3 class="font-semibold">Declare</h3>
          <p class="mt-2 text-sm text-base-content/80 text-pretty">
            Add an entry under <code class="text-xs">#docs</code> in <code class="text-xs">workspaced.cue</code> (source repo, path, destination id).
          </p>
        </div>
        <div class="rounded-box border border-base-300 bg-base-100 p-5">
          <h3 class="font-semibold">Apply</h3>
          <p class="mt-2 text-sm text-base-content/80 text-pretty">
            <code class="text-xs">workspaced codebase apply</code> places files under <code class="text-xs">content/&lt;tech&gt;/</code>. Renovate tracks lock pins.
          </p>
        </div>
        <div class="rounded-box border border-base-300 bg-base-100 p-5">
          <h3 class="font-semibold">Publish</h3>
          <p class="mt-2 text-sm text-base-content/80 text-pretty">
            Astro builds <code class="text-xs">/docs/:tech/…</code> and emits <code class="text-xs">llms.txt</code> + <code class="text-xs">llms-full.txt</code> only under each tech.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-tight">Documentation packs</h2>
        <a class="link link-primary text-sm" href={`${base}docs/`}>All packs</a>
      </div>
      <ul class="mt-8 grid gap-3 sm:grid-cols-2">
        {
          packs.map((p) => (
            <li>
              <a
                href={`${base}docs/${p.id}/`}
                class="flex h-full flex-col rounded-box border border-base-300 bg-base-100 p-5 transition-colors hover:border-primary/40 hover:bg-base-200/40"
              >
                <span class="text-xs font-medium uppercase tracking-wide text-primary">{p.id}</span>
                <span class="mt-1 font-semibold">{p.title}</span>
                <span class="mt-2 text-sm text-base-content/75 text-pretty">{p.description}</span>
                <span class="mt-3 text-xs text-base-content/50">
                  {p.pageCount > 0 ? `${p.pageCount} pages` : 'content pending apply'} · llms.txt
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
