---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPacks, getPagesForTech } from '../lib/docs';

const base = import.meta.env.BASE_URL;
const packs = getPacks().map((p) => ({
  ...p,
  pageCount: getPagesForTech(p.id).length,
}));
---

<BaseLayout
  title="docharvest"
  description="Documentation packs vendored with workspaced. Browse /docs/:tech; agents use per-tech llms.txt only."
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:py-12">
    <header class="mb-8 max-w-2xl border-b border-base-300 pb-6">
      <h1 class="font-display text-3xl font-medium tracking-[-0.02em] sm:text-4xl">Packs</h1>
      <p class="mt-2 text-sm leading-relaxed text-base-content/70 text-pretty sm:text-base">
        Upstream docs under <code class="rounded bg-base-200 px-1 font-mono text-[0.85em]">/docs/:tech</code>.
        Agents fetch that pack’s <code class="rounded bg-base-200 px-1 font-mono text-[0.85em]">llms.txt</code> — no site-wide index.
        Declared in <code class="rounded bg-base-200 px-1 font-mono text-[0.85em]">workspaced.cue</code>
        (<a class="link link-primary" href="https://github.com/lucasew/workspaced" target="_blank" rel="noopener noreferrer">workspaced</a>).
      </p>
    </header>

    {
      packs.length === 0 ? (
        <p class="text-sm text-base-content/60">No packs in manifest yet.</p>
      ) : (
        <ul class="divide-y divide-base-300 border-y border-base-300" role="list">
          {packs.map((p) => (
            <li>
              <a
                href={`${base}docs/${p.id}/`}
                class="group grid gap-2 py-5 transition-colors hover:bg-base-200/50 sm:grid-cols-[8rem_minmax(0,1fr)_auto] sm:items-baseline sm:gap-8 sm:px-1"
              >
                <span class="font-mono text-sm text-primary">{p.id}</span>
                <span class="min-w-0">
                  <span class="block text-lg font-semibold tracking-tight group-hover:text-primary">{p.title}</span>
                  <span class="mt-1 block max-w-2xl text-sm leading-relaxed text-base-content/70 text-pretty">
                    {p.description}
                  </span>
                </span>
                <span class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-base-content/50 sm:justify-end">
                  <span>{p.pageCount > 0 ? `${p.pageCount} pages` : 'pending'}</span>
                  <span
                    class="text-base-content/40 group-hover:text-primary"
                    title={`llms.txt for ${p.id}`}
                  >
                    llms.txt
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
