---
import BaseLayout from './BaseLayout.astro';
import { getPack, getTechNav } from '../lib/docs';

interface Props {
  tech: string;
  title: string;
  description?: string;
  /** Current page slug under the tech ('' for index) */
  slugPath?: string;
}

const { tech, title, description = '', slugPath = '' } = Astro.props;
const pack = getPack(tech);
const nav = getTechNav(tech);
const base = import.meta.env.BASE_URL;
const packTitle = pack?.title ?? tech;

// Group nav by first segment for nested packs (usage / development / …)
type NavItem = (typeof nav)[number];
const groups = new Map<string, NavItem[]>();
for (const item of nav) {
  const group = item.segments[0] ?? '_root';
  if (!groups.has(group)) groups.set(group, []);
  groups.get(group)!.push(item);
}

function hrefFor(itemSlug: string) {
  return itemSlug ? `${base}docs/${tech}/${itemSlug}/` : `${base}docs/${tech}/`;
}
---

<BaseLayout title={title} description={description || pack?.description}>
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-[16rem_minmax(0,1fr)]">
    <aside class="lg:sticky lg:top-6 lg:self-start">
      <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-base-content/60">Pack</p>
      <a href={`${base}docs/${tech}/`} class="mb-3 block font-semibold text-primary no-underline hover:underline">
        {packTitle}
      </a>
      <nav class="menu max-h-[70vh] overflow-y-auto rounded-box border border-base-300 bg-base-100 p-2 text-sm" aria-label={`${packTitle} docs`}>
        <ul>
          {
            [...groups.entries()].map(([group, items]) => (
              <>
                {group !== '_root' && (
                  <li class="menu-title mt-2 px-2 text-[0.65rem] uppercase tracking-wide opacity-60">
                    {group}
                  </li>
                )}
                {items.map((item) => (
                  <li>
                    <a
                      href={hrefFor(item.slugPath)}
                      class:list={[item.slugPath === slugPath && 'active bg-primary text-primary-content']}
                      aria-current={item.slugPath === slugPath ? 'page' : undefined}
                    >
                      {item.segments.length > 1 ? item.segments.slice(1).join(' / ') || item.title : item.title}
                    </a>
                  </li>
                ))}
              </>
            ))
          }
        </ul>
      </nav>
      <div class="mt-4 space-y-2 text-xs text-base-content/60">
        <p>
          <a class="link" href={`${base}docs/${tech}/llms.txt`}>llms.txt</a>
          ·
          <a class="link" href={`${base}docs/${tech}/llms-full.txt`}>llms-full.txt</a>
        </p>
        {
          pack?.source && (
            <p>
              Upstream:
              <a class="link" href={pack.source} target="_blank" rel="noopener noreferrer">
                source
              </a>
            </p>
          )
        }
      </div>
    </aside>
    <article class="min-w-0">
      <header class="mb-8 border-b border-base-300 pb-6">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-primary">{packTitle}</p>
        <h1 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{title}</h1>
        {description && <p class="mt-3 max-w-prose text-base-content/80 text-pretty">{description}</p>}
      </header>
      <div class="prose prose-neutral max-w-none dark:prose-invert prose-headings:font-semibold prose-a:text-primary prose-code:rounded-field prose-code:bg-base-200 prose-code:px-1 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
