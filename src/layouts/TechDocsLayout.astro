---
import BaseLayout from './BaseLayout.astro';
import { getPack, getTechNav } from '../lib/docs';

interface Props {
  tech: string;
  title: string;
  description?: string;
  /** Current page slug under the tech ('' for index) */
  slugPath?: string;
}

const { tech, title, description = '', slugPath = '' } = Astro.props;
const pack = getPack(tech);
const nav = getTechNav(tech);
const base = import.meta.env.BASE_URL;
const packTitle = pack?.title ?? tech;
const activeGroup = slugPath.split('/')[0] || '_root';

type NavItem = (typeof nav)[number];
const groups = new Map<string, NavItem[]>();
for (const item of nav) {
  const group = item.segments[0] ?? '_root';
  if (!groups.has(group)) groups.set(group, []);
  groups.get(group)!.push(item);
}

const groupEntries = [...groups.entries()];

function hrefFor(itemSlug: string) {
  return itemSlug ? `${base}docs/${tech}/${itemSlug}/` : `${base}docs/${tech}/`;
}

function labelFor(item: NavItem) {
  if (item.segments.length <= 1) return item.title;
  // drop group prefix; keep last 2 segments max for depth
  const rest = item.segments.slice(1);
  const shown = rest.length > 2 ? rest.slice(-2) : rest;
  return shown.join(' / ') || item.title;
}
---

<BaseLayout title={title} description={description || pack?.description}>
  <div class="mx-auto max-w-6xl px-4 py-6 sm:py-10">
    {/* Mobile: open drawer — sidebar is off-canvas until toggled */}
    <div class="mb-4 flex items-center gap-3 lg:hidden">
      <label
        for="docs-sidebar-toggle"
        class="btn btn-sm btn-outline border-base-300 gap-2 shadow-none"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10" />
        </svg>
        Pages
      </label>
      <a href={`${base}docs/${tech}/`} class="min-w-0 truncate font-mono text-xs text-primary">
        {tech}
      </a>
    </div>

    <div class="grid gap-8 lg:grid-cols-[15rem_minmax(0,1fr)]">
      {/* Checkbox drives mobile drawer; always “on” for layout on lg via CSS */}
      <input type="checkbox" id="docs-sidebar-toggle" class="peer/sidebar sr-only" />

      {/* Backdrop — only when open on small screens */}
      <label
        for="docs-sidebar-toggle"
        class="fixed inset-0 z-40 bg-neutral/50 opacity-0 pointer-events-none transition-opacity peer-checked/sidebar:pointer-events-auto peer-checked/sidebar:opacity-100 lg:hidden"
        aria-hidden="true"
      ></label>

      <aside
        class="docs-sidebar fixed inset-y-0 left-0 z-50 flex w-[min(18rem,88vw)] -translate-x-full flex-col border-r border-base-300 bg-base-100 transition-transform duration-200 ease-out peer-checked/sidebar:translate-x-0 lg:static lg:z-0 lg:w-auto lg:translate-x-0 lg:border-r-0 lg:bg-transparent"
        aria-label={`${packTitle} navigation`}
      >
        <div class="flex items-center justify-between gap-2 border-b border-base-300 px-3 py-3 lg:hidden">
          <span class="font-mono text-sm font-medium">{packTitle}</span>
          <label for="docs-sidebar-toggle" class="btn btn-ghost btn-sm btn-square" aria-label="Close navigation">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </label>
        </div>

        <div class="flex min-h-0 flex-1 flex-col gap-3 overflow-y-auto overscroll-contain px-3 py-3 lg:sticky lg:top-16 lg:max-h-[calc(100dvh-5rem)] lg:px-0 lg:py-0">
          <div class="hidden lg:block">
            <p class="mb-1 font-mono text-[0.65rem] uppercase tracking-wide text-base-content/50">Pack</p>
            <a
              href={`${base}docs/${tech}/`}
              class="block truncate font-semibold text-primary no-underline hover:underline"
            >
              {packTitle}
            </a>
          </div>

          <nav class="text-sm" aria-label={`${packTitle} pages`}>
            {
              groupEntries.map(([group, items]) => {
                const isOpen = group === activeGroup || group === '_root';
                if (group === '_root') {
                  return (
                    <ul class="mb-2 space-y-0.5">
                      {items.map((item) => (
                        <li>
                          <a
                            href={hrefFor(item.slugPath)}
                            class:list={[
                              'block rounded-field px-2 py-1.5 leading-snug hover:bg-base-200',
                              item.slugPath === slugPath && 'bg-primary font-medium text-primary-content hover:bg-primary',
                            ]}
                            aria-current={item.slugPath === slugPath ? 'page' : undefined}
                          >
                            {labelFor(item)}
                          </a>
                        </li>
                      ))}
                    </ul>
                  );
                }
                return (
                  <details class="group/nav mb-1 border-b border-base-300/80 pb-1" open={isOpen || undefined}>
                    <summary class="cursor-pointer list-none rounded-field px-2 py-1.5 font-mono text-[0.7rem] font-medium uppercase tracking-wide text-base-content/55 hover:bg-base-200 hover:text-base-content [&::-webkit-details-marker]:hidden">
                      <span class="inline-flex w-full items-center justify-between gap-2">
                        <span class="truncate">{group}</span>
                        <span class="text-base-content/40 transition-transform group-open/nav:rotate-90" aria-hidden="true">›</span>
                      </span>
                    </summary>
                    <ul class="mt-0.5 space-y-0.5 pb-1 pl-1">
                      {items.map((item) => (
                        <li>
                          <a
                            href={hrefFor(item.slugPath)}
                            class:list={[
                              'block rounded-field px-2 py-1 text-[0.8125rem] leading-snug text-base-content/85 hover:bg-base-200 hover:text-base-content',
                              item.slugPath === slugPath && 'bg-primary font-medium text-primary-content hover:bg-primary hover:text-primary-content',
                            ]}
                            aria-current={item.slugPath === slugPath ? 'page' : undefined}
                          >
                            {labelFor(item)}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                );
              })
            }
          </nav>

          <div class="mt-auto space-y-1 border-t border-base-300 pt-3 font-mono text-[0.65rem] text-base-content/50">
            <p>
              <a class="link link-hover" href={`${base}docs/${tech}/llms.txt`}>llms.txt</a>
              <span class="mx-1 opacity-40">·</span>
              <a class="link link-hover" href={`${base}docs/${tech}/llms-full.txt`}>full</a>
            </p>
            {
              pack?.source && (
                <p>
                  <a class="link link-hover" href={pack.source} target="_blank" rel="noopener noreferrer">
                    upstream
                  </a>
                </p>
              )
            }
          </div>
        </div>
      </aside>

      <article class="min-w-0">
        <header class="mb-8 border-b border-base-300 pb-6">
          <p class="mb-2 font-mono text-xs font-medium tracking-wide text-primary">{packTitle}</p>
          <h1 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{title}</h1>
          {description && <p class="mt-3 max-w-prose text-base-content/80 text-pretty">{description}</p>}
        </header>
        <div class="prose prose-neutral max-w-none dark:prose-invert prose-headings:font-semibold prose-a:text-primary prose-code:rounded-field prose-code:bg-base-200 prose-code:px-1 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none">
          <slot />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
