---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { orgLogoUrl } from '../lib/brand';
import { sitePath } from '../lib/site';
import { THEME_DARK, THEME_LIGHT, THEME_STORAGE_KEY } from '../lib/theme';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'docharvest',
  description = 'Vendored documentation packs. Browse /docs/:tech; agents use that pack\'s llms.txt.',
} = Astro.props;

const pageTitle = title === 'docharvest' ? title : `${title} · docharvest`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const brandLogo = orgLogoUrl(256);
// Local SVG for tab icon; org PNG for apple-touch (iOS prefers raster) and OG/twitter.
const favicon = sitePath('favicon.svg');
---

<!doctype html>
<html lang="en" data-theme={THEME_LIGHT}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a4d36" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={brandLogo} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={brandLogo} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content={brandLogo} />
    <title>{pageTitle}</title>
    <script
      is:inline
      set:html={`
      (function () {
        var KEY = ${JSON.stringify(THEME_STORAGE_KEY)};
        var LIGHT = ${JSON.stringify(THEME_LIGHT)};
        var DARK = ${JSON.stringify(THEME_DARK)};
        try {
          var t = localStorage.getItem(KEY);
          if (t === LIGHT || t === DARK) {
            document.documentElement.setAttribute('data-theme', t);
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', DARK);
          }
        } catch (e) {}
      })();
    `}
    />
  </head>
  <body class="flex min-h-dvh flex-col bg-base-100 text-base-content antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-field focus:bg-primary focus:px-3 focus:py-2 focus:text-primary-content">
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
