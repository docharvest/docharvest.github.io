---
/**
 * Ctrl/Cmd+K palette. One Orama dataset per pack at /search-indexes/<tech>.json
 */
import { getPacks } from '../lib/docs';

const packs = getPacks().map((p) => ({ id: p.id, title: p.title }));
---

<button
  type="button"
  class="btn btn-ghost btn-sm gap-2 font-normal text-base-content/70"
  data-search-open
  aria-haspopup="dialog"
  aria-controls="search-palette-dialog"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="size-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z"></path>
  </svg>
  <span class="hidden sm:inline">Search</span>
  <kbd class="kbd kbd-sm hidden opacity-60 md:inline-flex">⌘K</kbd>
</button>

<!-- Native dialog; avoid relying on daisyUI .modal open quirks -->
<dialog
  id="search-palette-dialog"
  class="search-palette-dialog w-[min(32rem,calc(100vw-2rem))] max-w-lg rounded-lg border border-base-300 bg-base-100 p-0 text-base-content shadow-lg open:flex open:flex-col"
  data-search-dialog
>
  <div class="flex flex-col gap-0">
    <div class="flex items-center gap-2 border-b border-base-300 px-3 py-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z"></path>
      </svg>
      <input
        type="search"
        class="min-h-10 min-w-0 flex-1 border-0 bg-transparent text-base text-base-content outline-none placeholder:text-base-content/40"
        placeholder="Search this pack only…"
        data-search-input
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="kbd kbd-sm shrink-0 opacity-50">esc</kbd>
    </div>
    <div class="border-b border-base-300 px-3 py-2">
      <label class="flex items-center gap-2 text-xs text-base-content/60">
        <span class="shrink-0">Pack</span>
        <select
          class="min-h-8 w-full max-w-xs rounded-md border border-base-300 bg-base-100 px-2 text-sm text-base-content"
          data-search-pack
          aria-label="Documentation pack"
        >
          {packs.map((p) => <option value={p.id}>{p.title}</option>)}
        </select>
      </label>
      <p class="mt-1 font-mono text-[0.65rem] text-base-content/40" data-search-status>
        One dataset per project — results never cross packs.
      </p>
    </div>
    <ul class="max-h-72 list-none overflow-y-auto p-2" data-search-results role="listbox"></ul>
  </div>
</dialog>

<style is:global>
  .search-palette-dialog {
    margin: auto;
  }
  .search-palette-dialog::backdrop {
    background: color-mix(in oklab, var(--color-neutral, #000) 45%, transparent);
  }
</style>

<!-- Open / keyboard: always works even if Orama fails to load -->
<script is:inline >
  (function () {
    var dialog = document.getElementById('search-palette-dialog');
    if (!dialog || typeof dialog.showModal !== 'function') return;

    var input = dialog.querySelector('[data-search-input]');
    var packSelect = dialog.querySelector('[data-search-pack]');
    var resultsEl = dialog.querySelector('[data-search-results]');
    var statusEl = dialog.querySelector('[data-search-status]');

    function techFromLocation() {
      var m = location.pathname.match(/\/docs\/([^/]+)/);
      return m ? m[1] : '';
    }

    function syncPackFromRoute() {
      if (!packSelect) return;
      var t = techFromLocation();
      if (!t) return;
      for (var i = 0; i < packSelect.options.length; i++) {
        if (packSelect.options[i].value === t) {
          packSelect.value = t;
          break;
        }
      }
    }

    function openPalette() {
      syncPackFromRoute();
      try {
        dialog.showModal();
      } catch (err) {
        dialog.setAttribute('open', '');
      }
      if (input) {
        input.value = '';
        setTimeout(function () {
          input.focus();
        }, 0);
      }
      if (statusEl) {
        var tech = packSelect && packSelect.value;
        statusEl.textContent = tech
          ? 'Dataset: ' + tech + ' only (no cross-pack mix)'
          : 'Select a pack.';
      }
      if (resultsEl) resultsEl.innerHTML = '';
      document.dispatchEvent(new CustomEvent('docharvest:search-open'));
    }

    function closePalette() {
      if (dialog.open) dialog.close();
    }

    document.addEventListener(
      'click',
      function (e) {
        var t = e.target;
        if (!t || !t.closest) return;
        if (t.closest('[data-search-open]')) {
          e.preventDefault();
          openPalette();
        }
      },
      true,
    );

    document.addEventListener('keydown', function (e) {
      var key = e.key || e.code;
      var isK = key === 'k' || key === 'K' || e.code === 'KeyK';
      if (!(e.metaKey || e.ctrlKey) || !isK) return;
      // Don't steal from inputs except our search field
      var tag = (e.target && e.target.tagName) || '';
      if (
        (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) &&
        !(e.target && e.target.hasAttribute && e.target.hasAttribute('data-search-input'))
      ) {
        return;
      }
      e.preventDefault();
      e.stopPropagation();
      if (dialog.open) closePalette();
      else openPalette();
    });

    dialog.addEventListener('click', function (e) {
      // click backdrop (dialog itself)
      if (e.target === dialog) closePalette();
    });
  })();
</script>

<!-- Orama restore + search (module; may fail without breaking open/close) -->
<script>
  import { restore } from '@orama/plugin-data-persistence';

  const dialog = document.getElementById('search-palette-dialog');
  const input = dialog?.querySelector('[data-search-input]');
  const packSelect = dialog?.querySelector('[data-search-pack]');
  const resultsEl = dialog?.querySelector('[data-search-results]');
  const statusEl = dialog?.querySelector('[data-search-status]');
  if (!dialog || !input || !packSelect || !resultsEl || !statusEl) {
    console.warn('[search] palette DOM incomplete');
  } else {
    /** @type {Map<string, Promise<any>>} */
    const dbByTech = new Map();

    function loadDb(tech) {
      if (!tech) return Promise.resolve(null);
      const cached = dbByTech.get(tech);
      if (cached) return cached;
      const p = fetch(`/search-indexes/${encodeURIComponent(tech)}.json`)
        .then((res) => {
          if (!res.ok) throw new Error(`index ${tech} HTTP ${res.status}`);
          return res.text();
        })
        .then((text) => restore('json', text))
        .catch((err) => {
          dbByTech.delete(tech);
          statusEl.textContent = `Failed to load index for “${tech}”.`;
          console.error(err);
          return null;
        });
      dbByTech.set(tech, p);
      return p;
    }

    function renderHits(hits) {
      resultsEl.innerHTML = '';
      if (!hits?.length) {
        const empty = document.createElement('li');
        empty.className = 'px-3 py-2 text-sm text-base-content/50';
        empty.textContent = input.value.trim()
          ? 'No matches in this pack.'
          : 'Type to search — only the selected pack is queried.';
        resultsEl.appendChild(empty);
        return;
      }
      for (const hit of hits) {
        const doc = hit.document;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = doc.path;
        a.className =
          'block rounded-md px-3 py-2 hover:bg-base-200 focus:bg-base-200 focus:outline-none';
        const t = document.createElement('span');
        t.className = 'block font-medium';
        t.textContent = doc.title;
        const s = document.createElement('span');
        s.className = 'block font-mono text-[0.65rem] text-base-content/45';
        s.textContent = doc.path;
        a.append(t, s);
        li.appendChild(a);
        resultsEl.appendChild(li);
      }
    }

    let searchTimer = 0;
    function runSearch() {
      const tech = packSelect.value;
      const term = input.value.trim();
      if (!tech) {
        renderHits([]);
        return;
      }
      statusEl.textContent = `Dataset: ${tech} only (no cross-pack mix)`;
      if (!term) {
        renderHits([]);
        return;
      }
      loadDb(tech)
        .then((db) => {
          if (!db) return null;
          return db.search({
            term,
            limit: 12,
            properties: ['title', 'description', 'body', 'slugPath'],
          });
        })
        .then((res) => {
          if (res) renderHits(res.hits);
        });
    }

    function onOpen() {
      const tech = packSelect.value;
      statusEl.textContent = tech ? `Loading “${tech}” index…` : 'Select a pack.';
      renderHits([]);
      if (tech) {
        loadDb(tech).then(() => {
          statusEl.textContent = `Dataset: ${tech} only (no cross-pack mix)`;
        });
      }
    }

    document.addEventListener('docharvest:search-open', onOpen);

    input.addEventListener('input', () => {
      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(runSearch, 120);
    });

    packSelect.addEventListener('change', () => {
      input.value = '';
      renderHits([]);
      const tech = packSelect.value;
      statusEl.textContent = tech ? `Loading “${tech}” index…` : 'Select a pack.';
      if (tech) {
        loadDb(tech).then(() => {
          statusEl.textContent = `Dataset: ${tech} only (no cross-pack mix)`;
          input.focus();
        });
      }
    });

    resultsEl.addEventListener('click', (e) => {
      const a = e.target.closest('a');
      if (a?.href && dialog.open) dialog.close();
    });
  }
</script>
