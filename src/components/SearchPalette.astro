---
/** Ctrl/Cmd+K search for the open /docs/<tech>/ pack only. */
---

<button
  type="button"
  class="btn btn-ghost btn-sm gap-2 font-normal text-base-content/70"
  data-search-open
  aria-haspopup="dialog"
  aria-controls="search-palette-dialog"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="size-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z"></path>
  </svg>
  <span class="hidden sm:inline">Search</span>
  <kbd class="kbd kbd-sm hidden opacity-60 md:inline-flex">⌘K</kbd>
</button>

<dialog
  id="search-palette-dialog"
  class="search-palette-dialog w-[min(32rem,calc(100vw-2rem))] max-w-lg rounded-lg border border-base-300 bg-base-100 p-0 text-base-content shadow-lg"
>
  <div class="flex flex-col">
    <div class="flex items-center gap-2 border-b border-base-300 px-3 py-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z"></path>
      </svg>
      <input
        type="search"
        class="min-h-10 min-w-0 flex-1 border-0 bg-transparent text-base text-base-content outline-none placeholder:text-base-content/40"
        placeholder="Search this pack..."
        data-search-input
        autocomplete="off"
        spellcheck="false"
        role="combobox"
        aria-autocomplete="list"
        aria-controls="search-palette-results"
        aria-expanded="false"
      />
      <kbd class="kbd kbd-sm shrink-0 opacity-50">esc</kbd>
    </div>
    <ul
      id="search-palette-results"
      class="max-h-72 list-none overflow-y-auto p-2"
      data-search-results
      role="listbox"
    ></ul>
  </div>
</dialog>

<style is:global>
  .search-palette-dialog {
    margin: auto;
  }
  .search-palette-dialog::backdrop {
    background: color-mix(in oklab, #000 45%, transparent);
  }
  .search-palette-dialog [data-search-results] a[data-active='true'] {
    background-color: color-mix(in oklab, var(--color-primary, #2d6a4f) 18%, var(--color-base-200, #eee));
  }
</style>

<script>
  import MiniSearch from 'minisearch';
  import { sitePath } from '../lib/site';

  type SearchHit = { title: string; path: string };
  type PackIndex = { documents?: SearchHit[] };

  const dialogEl = document.getElementById('search-palette-dialog');
  const inputEl = dialogEl?.querySelector('[data-search-input]');
  const resultsNode = dialogEl?.querySelector('[data-search-results]');

  if (
    dialogEl instanceof HTMLDialogElement &&
    inputEl instanceof HTMLInputElement &&
    resultsNode instanceof HTMLElement
  ) {
    const dialog = dialogEl;
    const input = inputEl;
    const resultsEl = resultsNode;

    const cache = new Map<string, Promise<MiniSearch<SearchHit> | null>>();
    let currentHits: SearchHit[] = [];
    let activeIndex = -1;
    let searchTimer = 0;

    function techFromLocation(): string {
      const m = location.pathname.match(/\/docs\/([^/]+)/);
      return m?.[1] ?? '';
    }

    function loadPack(tech: string): Promise<MiniSearch<SearchHit> | null> {
      if (!tech) return Promise.resolve(null);
      const hit = cache.get(tech);
      if (hit) return hit;
      const p = fetch(sitePath(`search-indexes/${encodeURIComponent(tech)}.json`))
        .then((res) => {
          if (!res.ok) throw new Error(`index HTTP ${res.status}`);
          return res.json() as Promise<PackIndex>;
        })
        .then((data) => {
          const mini = new MiniSearch<SearchHit>({
            fields: ['title', 'description', 'body', 'slugPath'],
            storeFields: ['title', 'path', 'slugPath', 'tech'],
            searchOptions: {
              boost: { title: 3, description: 1.5, slugPath: 1.2 },
              prefix: true,
              fuzzy: 0.15,
            },
          });
          mini.addAll(data.documents || []);
          return mini;
        })
        .catch((err: unknown) => {
          cache.delete(tech);
          console.error('[search]', err);
          return null;
        });
      cache.set(tech, p);
      return p;
    }

    function resultLinks(): HTMLAnchorElement[] {
      return [...resultsEl.querySelectorAll<HTMLAnchorElement>('a[href]')];
    }

    function setActive(index: number) {
      const links = resultLinks();
      if (!links.length) {
        activeIndex = -1;
        input.removeAttribute('aria-activedescendant');
        return;
      }
      activeIndex = ((index % links.length) + links.length) % links.length;
      links.forEach((a, i) => {
        const on = i === activeIndex;
        a.toggleAttribute('data-active', on);
        a.setAttribute('aria-selected', on ? 'true' : 'false');
        if (on) {
          if (!a.id) a.id = `search-hit-${i}`;
          input.setAttribute('aria-activedescendant', a.id);
          a.scrollIntoView({ block: 'nearest' });
        }
      });
    }

    function renderHits(rows: SearchHit[] | null | undefined) {
      currentHits = rows || [];
      activeIndex = -1;
      resultsEl.innerHTML = '';
      input.setAttribute('aria-expanded', currentHits.length ? 'true' : 'false');

      const tech = techFromLocation();
      if (!currentHits.length) {
        const empty = document.createElement('li');
        empty.className = 'px-3 py-2 text-sm text-base-content/50';
        if (!tech) empty.textContent = 'Open a pack under /docs/<tech>/ to search.';
        else if (!input.value.trim()) empty.textContent = 'Type to search this pack.';
        else empty.textContent = 'No matches.';
        resultsEl.appendChild(empty);
        input.removeAttribute('aria-activedescendant');
        return;
      }

      currentHits.forEach((doc, i) => {
        const li = document.createElement('li');
        li.setAttribute('role', 'presentation');
        const a = document.createElement('a');
        a.href = doc.path;
        a.id = `search-hit-${i}`;
        a.setAttribute('role', 'option');
        a.setAttribute('aria-selected', 'false');
        a.className =
          'block rounded-md px-3 py-2 hover:bg-base-200 focus:bg-base-200 focus:outline-none';
        const t = document.createElement('span');
        t.className = 'block font-medium';
        t.textContent = doc.title;
        const s = document.createElement('span');
        s.className = 'block font-mono text-[0.65rem] text-base-content/45';
        s.textContent = doc.path;
        a.append(t, s);
        li.appendChild(a);
        resultsEl.appendChild(li);
      });

      setActive(0);
    }

    function runSearch() {
      const tech = techFromLocation();
      const term = input.value.trim();
      if (!tech || !term) {
        renderHits([]);
        return;
      }
      void loadPack(tech).then((mini) => {
        if (!mini) {
          renderHits([]);
          return;
        }
        const rows = mini.search(term).slice(0, 12).map((r) => {
          const stored = r as { title?: string; path?: string };
          return { title: stored.title ?? '', path: stored.path ?? '' };
        });
        renderHits(rows);
      });
    }

    function goActive() {
      const links = resultLinks();
      const active = links[activeIndex];
      if (activeIndex < 0 || !active) return;
      const href = active.href;
      closePalette();
      location.assign(href);
    }

    function openPalette() {
      const tech = techFromLocation();
      try {
        dialog.showModal();
      } catch {
        dialog.setAttribute('open', '');
      }
      input.value = '';
      renderHits([]);
      if (tech) void loadPack(tech);
      queueMicrotask(() => input.focus());
    }

    function closePalette() {
      if (dialog.open) dialog.close();
      activeIndex = -1;
      input.removeAttribute('aria-activedescendant');
    }

    document.querySelectorAll('[data-search-open]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openPalette();
      });
    });

    document.addEventListener('keydown', (e) => {
      const isK = e.key === 'k' || e.key === 'K' || e.code === 'KeyK';
      if (!(e.metaKey || e.ctrlKey) || !isK) return;
      const el = e.target;
      const otherField =
        el instanceof HTMLElement &&
        (el instanceof HTMLInputElement ||
          el instanceof HTMLTextAreaElement ||
          el.isContentEditable) &&
        !el.hasAttribute('data-search-input');
      if (otherField) return;
      e.preventDefault();
      if (dialog.open) closePalette();
      else openPalette();
    });

    input.addEventListener('keydown', (e) => {
      const links = resultLinks();
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!links.length) return;
        setActive(activeIndex < 0 ? 0 : activeIndex + 1);
        return;
      }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (!links.length) return;
        setActive(activeIndex < 0 ? links.length - 1 : activeIndex - 1);
        return;
      }
      if (e.key === 'Enter') {
        if (activeIndex >= 0 && links[activeIndex]) {
          e.preventDefault();
          goActive();
        }
        return;
      }
      if (e.key === 'Home' && links.length) {
        e.preventDefault();
        setActive(0);
        return;
      }
      if (e.key === 'End' && links.length) {
        e.preventDefault();
        setActive(links.length - 1);
      }
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closePalette();
    });

    input.addEventListener('input', () => {
      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(runSearch, 100);
    });

    resultsEl.addEventListener('mousemove', (e) => {
      const a = e.target instanceof Element ? e.target.closest('a[href]') : null;
      if (!(a instanceof HTMLAnchorElement) || !resultsEl.contains(a)) return;
      const links = resultLinks();
      const i = links.indexOf(a);
      if (i >= 0 && i !== activeIndex) setActive(i);
    });

    resultsEl.addEventListener('click', (e) => {
      const a = e.target instanceof Element ? e.target.closest('a') : null;
      if (a instanceof HTMLAnchorElement && a.href) closePalette();
    });
  }
</script>
