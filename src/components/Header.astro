---
import ThemeChooser from './ThemeChooser.astro';

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = path === '' || path === '/' || path === base.replace(/\/$/, '');
const links = [
  { href: `${base}`, label: 'Home', match: (p: string) => p === '' || p === '/' || p === base.replace(/\/$/, '') },
  { href: `${base}docs/`, label: 'Docs', match: (p: string) => p.includes('/docs') },
  { href: 'https://github.com/docharvest', label: 'GitHub', external: true },
];
---

<header
  class:list={[
    'sticky top-0 z-40 border-b backdrop-blur-md',
    isHome
      ? 'border-primary-content/10 bg-primary/95 text-primary-content'
      : 'border-base-300 bg-base-100/90 text-base-content',
  ]}
>
  <div class="navbar mx-auto max-w-6xl min-h-14 px-4">
    <div class="navbar-start gap-2">
      <a
        href={base}
        class:list={[
          'flex items-center gap-2.5 font-semibold tracking-tight no-underline',
          isHome ? 'text-primary-content' : 'text-base-content',
        ]}
      >
        <span
          class:list={[
            'flex size-8 items-center justify-center rounded-sm font-mono text-xs font-bold',
            isHome ? 'bg-primary-content text-primary' : 'bg-primary text-primary-content',
          ]}
        >
          DH
        </span>
        <span class="font-mono text-sm tracking-tight">docharvest</span>
      </a>
    </div>
    <div class="navbar-center hidden md:flex">
      <nav class="menu menu-horizontal gap-0.5 px-1" aria-label="Primary">
        {
          links.map((link) =>
            link.external ? (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={['font-medium', isHome && 'text-primary-content/90 hover:bg-primary-content/10']}
                >
                  {link.label}
                </a>
              </li>
            ) : (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'font-medium',
                    isHome
                      ? link.match(path)
                        ? 'bg-primary-content/15 text-primary-content'
                        : 'text-primary-content/90 hover:bg-primary-content/10'
                      : link.match(path) && 'bg-base-200',
                  ]}
                  aria-current={link.match(path) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ),
          )
        }
      </nav>
    </div>
    <div class="navbar-end gap-1">
      {!isHome && <ThemeChooser />}
      <div class="dropdown dropdown-end md:hidden">
        <div
          tabindex="0"
          role="button"
          class:list={['btn btn-ghost btn-sm', isHome && 'text-primary-content hover:bg-primary-content/10']}
          aria-label="Menu"
        >
          Menu
        </div>
        <ul
          tabindex="0"
          class="dropdown-content menu z-50 mt-2 w-48 rounded-box border border-base-300 bg-base-100 p-2 text-base-content shadow-none"
        >
          {
            links.map((link) => (
              <li>
                {link.external ? (
                  <a href={link.href} target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                ) : (
                  <a href={link.href} aria-current={link.match(path) ? 'page' : undefined}>
                    {link.label}
                  </a>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</header>
