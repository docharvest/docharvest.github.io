---
import SearchPalette from './SearchPalette.astro';
import ThemeChooser from './ThemeChooser.astro';
import { ORG, orgLogoUrl } from '../lib/brand';

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const brandLogo = orgLogoUrl(64);
const links = [
  { href: `${base}`, label: 'Packs', match: (p: string) => p === '' || p === '/' || p === base.replace(/\/$/, '') },
  { href: `${base}docs/`, label: 'Docs', match: (p: string) => p.includes('/docs') },
  { href: `https://github.com/${ORG}`, label: 'GitHub', external: true },
];
---

<header class="sticky top-0 z-40 border-b border-base-300 bg-base-100/95 backdrop-blur-md">
  <div class="navbar mx-auto max-w-6xl min-h-12 px-4">
    <div class="navbar-start gap-2">
      <a href={base} class="flex items-center gap-2.5 font-semibold tracking-tight text-base-content no-underline">
        <img
          src={brandLogo}
          alt=""
          width="28"
          height="28"
          class="size-7 shrink-0 rounded-md border border-base-300 bg-base-200 object-cover"
          decoding="async"
        />
        <span class="font-mono text-sm tracking-tight">{ORG}</span>
      </a>
    </div>
    <div class="navbar-center hidden md:flex">
      <nav class="menu menu-horizontal gap-0.5 px-1" aria-label="Primary">
        {
          links.map((link) =>
            link.external ? (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer" class="font-medium">
                  {link.label}
                </a>
              </li>
            ) : (
              <li>
                <a
                  href={link.href}
                  class:list={['font-medium', link.match(path) && 'bg-base-200']}
                  aria-current={link.match(path) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ),
          )
        }
      </nav>
    </div>
    <div class="navbar-end gap-1">
      <SearchPalette />
      <ThemeChooser />
      <div class="dropdown dropdown-end md:hidden">
        <div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Menu">
          Menu
        </div>
        <ul tabindex="0" class="dropdown-content menu z-50 mt-2 w-48 rounded-box border border-base-300 bg-base-100 p-2 shadow-none">
          {
            links.map((link) => (
              <li>
                {link.external ? (
                  <a href={link.href} target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                ) : (
                  <a href={link.href} aria-current={link.match(path) ? 'page' : undefined}>
                    {link.label}
                  </a>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</header>
