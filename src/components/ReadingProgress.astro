---
/**
 * Fixed top reading progress bar.
 * 100% when the bottom of the viewport reaches the end-of-article anchor
 * (same approach as lucasew.github.io ProgressBar).
 */
---

<progress
  id="reading-progress"
  class="reading-progress"
  value="0"
  max="100"
  aria-label="Reading progress"
></progress>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 0.25rem;
    z-index: 50;
    appearance: none;
    border: none;
    color: var(--color-primary);
    background: transparent;
    pointer-events: none;
  }

  .reading-progress::-moz-progress-bar {
    background: currentColor;
  }

  .reading-progress::-webkit-progress-bar {
    background: transparent;
  }

  .reading-progress::-webkit-progress-value {
    background: currentColor;
  }
</style>

<script>
  let teardown: (() => void) | null = null;

  function documentOffsetTop(el: HTMLElement): number {
    // Walk offsetParent chain. offsetTop alone is relative to the nearest
    // positioned ancestor, which is wrong inside the nested docs layout.
    let top = 0;
    let node: HTMLElement | null = el;
    while (node) {
      top += node.offsetTop;
      const parent: Element | null = node.offsetParent;
      node = parent instanceof HTMLElement ? parent : null;
    }
    return top;
  }

  function bindReadingProgress() {
    teardown?.();
    teardown = null;

    const progress = document.getElementById('reading-progress');
    const anchor = document.getElementById('article-end');

    if (!(progress instanceof HTMLProgressElement)) return;

    if (!(anchor instanceof HTMLElement)) {
      progress.style.display = 'none';
      return;
    }
    progress.style.display = 'block';

    const onscroll = () => {
      // Scrollable distance until the bottom of the viewport reaches the anchor.
      const scrollLength = documentOffsetTop(anchor) - window.innerHeight;

      if (scrollLength <= 0) {
        progress.value = 100;
        return;
      }

      const y = (window.scrollY * 100) / scrollLength;
      progress.value = Math.min(100, Math.max(0, Math.floor(y)));
    };

    window.addEventListener('scroll', onscroll, { passive: true });
    window.addEventListener('resize', onscroll, { passive: true });
    onscroll();

    const onBeforeSwap = () => {
      window.removeEventListener('scroll', onscroll);
      window.removeEventListener('resize', onscroll);
    };
    document.addEventListener('astro:before-swap', onBeforeSwap, { once: true });

    teardown = () => {
      onBeforeSwap();
    };
  }

  document.addEventListener('astro:page-load', bindReadingProgress);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindReadingProgress, { once: true });
  } else {
    bindReadingProgress();
  }
</script>
