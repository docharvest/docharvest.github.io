---
import { ORG, ORG_GITHUB } from '../lib/brand';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const siteSource = `${ORG_GITHUB}/docharvest.github.io`;
---

<footer class="mt-auto border-t border-base-300 bg-base-200">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 text-sm text-base-content/75 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="font-mono text-sm font-medium text-base-content">{ORG}</p>
      <p class="mt-1 max-w-sm text-pretty">
        Upstream docs vendored into versioned packs. Browse in the browser, or pull each tech's llms.txt.
      </p>
    </div>
    <nav class="flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs" aria-label="Footer">
      <a class="link link-hover" href={`${base}docs/`}>/docs/</a>
      <a class="link link-hover" href={ORG_GITHUB} target="_blank" rel="noopener noreferrer">github.com/{ORG}</a>
      <a
        class="link link-hover"
        href={siteSource}
        target="_blank"
        rel="noopener noreferrer"
      >
        site source
      </a>
    </nav>
  </div>
  <div class="border-t border-base-300">
    <p class="mx-auto max-w-6xl px-4 py-3 font-mono text-[0.65rem] text-base-content/50">
      © {year} · packs via
      <a class="link link-hover" href="https://github.com/lucasew/workspaced" target="_blank" rel="noopener noreferrer">workspaced</a>
      · llms.txt is per tech
    </p>
  </div>
</footer>
